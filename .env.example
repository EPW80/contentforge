# Postgres (matches docker-compose.yml)
DATABASE_URI=postgres://contentforge:contentforge@127.0.0.1:5434/contentforge

# Payload — in real deployments generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-in-prod

# On-demand revalidation (URL of the Next.js server; dev runs on :3000)
NEXT_REVALIDATE_URL=http://localhost:3000
# In real deployments generate with: openssl rand -hex 32
REVALIDATE_SECRET=change-me-in-prod

# Public base URL of the deployment (e.g. https://contentforge.vercel.app).
# Optional locally; used by Payload for generated absolute URLs.
NEXT_PUBLIC_SERVER_URL=

# Max pg connections per process (optional; default 5). Keep small on
# serverless — each function instance opens its own pool.
PG_POOL_MAX=

# S3 / MinIO (matches docker-compose.yml minio service)
# IMPORTANT: on real AWS S3, leave S3_ENDPOINT unset — setting it enables
# MinIO-style path-style addressing.
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_BUCKET=contentforge
S3_ACCESS_KEY=contentforge
S3_SECRET_KEY=contentforge
