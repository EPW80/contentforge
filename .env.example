# Postgres (matches docker-compose.yml)
DATABASE_URI=postgres://contentforge:contentforge@127.0.0.1:5434/contentforge

# Payload
PAYLOAD_SECRET=change-me-in-prod

# On-demand revalidation
NEXT_REVALIDATE_URL=http://localhost:3000
REVALIDATE_SECRET=change-me-in-prod

# S3 / MinIO (matches docker-compose.yml minio service)
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_BUCKET=contentforge
S3_ACCESS_KEY=contentforge
S3_SECRET_KEY=contentforge
